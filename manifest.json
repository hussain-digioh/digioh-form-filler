{
  "manifest_version": 3,
  "name": "Digioh QA Form Filler",
  "version": "1.1.0",
  "description": "Auto-fills Digioh campaign forms the moment they appear. Click the icon to manage presets.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "QA Form Filler"
  },
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "all_frames": true,
    "run_at": "document_idle"
  }]
}
